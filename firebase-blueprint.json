{
  "entities": {
    "Destination": {
      "title": "Destination",
      "description": "A travel destination with detailed tour information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "weather": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "sunsetTitle": { "type": "string" },
        "sunsetDescription": { "type": "string" },
        "sunsetDescriptionSecondary": { "type": "string" },
        "sunsetImage": { "type": "string" },
        "duration": { "type": "string" },
        "meals": { "type": "string" },
        "transportation": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "weKnowWhatYouWant": { "type": "string" },
        "weKnowWhatYouWantSecondary": { "type": "string" }
      },
      "required": ["name", "location", "description", "image", "price", "duration"]
    },
    "Hotel": {
      "title": "Hotel",
      "description": "A hotel linked to a destination",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "destinationId": { "type": "string" },
        "rating": { "type": "number" },
        "price": { "type": "number" },
        "location": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "contact": { "type": "string" },
        "image": { "type": "string" },
        "images": {
          "type": "array",
          "items": { "type": "string" }
        },
        "amenities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "highlights": {
          "type": "array",
          "items": { "type": "string" }
        },
        "description": { "type": "string" }
      },
      "required": ["name", "destinationId", "rating", "price", "location", "image"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "birthDate": { "type": "string" },
        "gender": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "country": { "type": "string" },
        "address": { "type": "string" },
        "preferredDestinations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "travelHistory": {
          "type": "array",
          "items": { "type": "string" }
        },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "fullName"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A user's travel booking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["flight", "hotel", "package"] },
        "itemId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "image": { "type": "string" },
        "price": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "guests": { "type": "string" }
      },
      "required": ["userId", "type", "status", "price"]
    }
  },
  "firestore": {
    "/destinations/{destinationId}": {
      "schema": "Destination",
      "description": "Collection of travel destinations"
    },
    "/hotels/{hotelId}": {
      "schema": "Hotel",
      "description": "Collection of hotels"
    },
    "/users/{uid}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of user bookings"
    }
  }
}
