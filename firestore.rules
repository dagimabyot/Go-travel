rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: destinations
    // Fields:
    //   - name: string (required)
    //   - location: string (required)
    //   - description: string (required)
    //   - weather: string (optional)
    //   - price: number (required)
    //   - image: string (required)
    //   - images: list (optional)
    //   - highlights: list of maps {title, description} (optional)
    //   - duration: string (required)
    //   - meals: string (optional)
    //   - transportation: string (optional)
    //   - category: string (optional)
    //   - rating: number (optional)
    //
    // Collection: hotels
    // Fields:
    //   - name: string (required)
    //   - destinationId: string (required)
    //   - rating: number (required)
    //   - price: number (required)
    //   - location: string (required)
    //   - image: string (required)
    //   - amenities: list (optional)
    //   - highlights: list (optional)
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - fullName: string (required)
    //   - role: string (enum: user, admin)
    //
    // Collection: bookings
    // Fields:
    //   - userId: string (required)
    //   - type: string (enum: flight, hotel, package)
    //   - itemId: string (required)
    //   - status: string (required, enum: pending, confirmed, cancelled)
    //   - price: number (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "dagim045@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidDestination(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.price is number && data.price >= 0 &&
             data.image is string &&
             data.duration is string;
    }

    function isValidHotel(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.destinationId is string &&
             data.rating is number && data.rating >= 0 && data.rating <= 5 &&
             data.price is number && data.price >= 0 &&
             data.location is string &&
             data.image is string;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100;
    }

    function isValidBooking(data) {
      return data.userId == request.auth.uid &&
             data.type in ['flight', 'hotel', 'package'] &&
             data.status in ['pending', 'confirmed', 'cancelled'] &&
             data.price is number && data.price >= 0;
    }

    // Destinations: Everyone can read, only admins can write
    match /destinations/{destinationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidDestination(request.resource.data);
    }

    // Hotels: Everyone can read, only admins can write
    match /hotels/{hotelId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidHotel(request.resource.data);
    }

    // Bookings: Users can read/write their own bookings, admins can read/write all
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isValidBooking(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId && isValidBooking(request.resource.data)));
      allow delete: if isAdmin();
    }

    // Users: Users can read/write their own profile, admins can read all
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }
  }
}
